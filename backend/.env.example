DATABASE_URL=sqlite:///./capdash.db
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173
ENVIRONMENT=development

# CrowdStrike Falcon API (leave blank to use mock data)
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
CROWDSTRIKE_BASE_URL=https://api.us-2.crowdstrike.com

# Zabbix API (leave blank to use mock data)
ZABBIX_URL=https://your-zabbix-instance
ZABBIX_API_TOKEN=
ZABBIX_GROUP=CAP  # restrict all queries to this host group name

# Outpost24 Outscan API (leave blank to use mock data)
OUTPOST24_URL=
OUTPOST24_USERNAME=
OUTPOST24_PASSWORD=
